{
    "name": "zyra-ass",
    "private": true,
    "workspaces": [
        "backend",
        "frontend",
        "packages/shared"
    ],
    "scripts": {
        "dev": "bun run --cwd backend dev & bun run --cwd frontend dev",
        "dev:backend": "bun run --cwd backend dev",
        "dev:frontend": "bun run --cwd frontend dev",
        "test": "bun run --cwd backend test && bun run --cwd frontend test",
        "test:backend": "bun run --cwd backend test",
        "test:frontend": "bun run --cwd frontend test",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "deploy": "bun run --cwd frontend build && rm -rf backend/public && cp -r frontend/dist backend/public",
        "serve": "bun run --cwd backend start"
    },
    "devDependencies": {
        "prettier": "^3.8.3"
    }
}
